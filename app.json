{
  "expo": {
    "name": "Shun",
    "slug": "Shun",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/android-icon-background.png",
    "scheme": "shun",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/android-icon-background.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ridamsh.Shun"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "86382114-82a0-45e3-ae75-1a9b68379360"
      }
    }
  }
}
